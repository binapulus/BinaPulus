// ═══════════════════════════════════════════════════════════════
//  BinaPlus — Firestore Security Rules
//  Versiyon : 2.0
//  Güncelleme: Rol hiyerarşisi tam kuruldu
//
//  ROL HİYERARŞİSİ (üstten alta — üst her zaman altı kapsar):
//
//    1. Süper Admin
//       - admin/config.adminUids listesinde Firebase UID'si var
//       - Tüm binalara, tüm sub-collection'lara tam erişim
//       - Abonelik yönetimi, bina silme, sistem ayarları
//
//    2. Bina Yöneticisi
//       - binalar/{binaId}.yoneticiUid == request.auth.uid
//       - Sadece kendi binasına tam erişim
//       - Abonelik alanlarına dokunamaz (sadece süper admin)
//       - Başka binanın hiçbir verisini okuyamaz/yazamaz
//
//    3. Sakin
//       - Firebase Auth ile giriş YAPAMAZ (client-side SHA-256)
//       - Firestore'a doğrudan erişimi yoktur
//       - Yönetici adına işlem yapılır (server-side proxy mantığı)
//       - NOT: Sakin işlemleri index.html'deki yönetici oturumu
//         üzerinden değil, ayrı bir "sakin token" mekanizmasıyla
//         yapılacaksa bu rules güncellenmelidir.
//
//  GENİŞLETME KURALI:
//    Yeni sub-collection eklendiğinde sadece ilgili match bloğunu
//    kopyalayıp düzenle. İsGuncel() ve isSuperAdmin() fonksiyonlarına
//    dokunma.
// ═══════════════════════════════════════════════════════════════

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    //  YARDIMCI FONKSİYONLAR
    // ─────────────────────────────────────────────────────────

    // Kullanıcı Firebase Auth ile giriş yapmış mı?
    function isAuth() {
      return request.auth != null;
    }

    // Süper Admin: admin/config.adminUids listesinde UID var mı?
    function isSuperAdmin() {
      return isAuth()
        && exists(/databases/$(database)/documents/anayonetici/config)
        && request.auth.uid in
           get(/databases/$(database)/documents/anayonetici/config).data.adminUids;
    }

    // Bina Yöneticisi: bu binanın yoneticiUid'si benim mi?
    function isBinaYoneticisi(binaId) {
      return isAuth()
        && exists(/databases/$(database)/documents/binalar/$(binaId))
        && get(/databases/$(database)/documents/binalar/$(binaId)).data.yoneticiUid
           == request.auth.uid;
    }

    // Süper Admin VEYA Bina Yöneticisi (bu binanın)
    function isYonetici(binaId) {
      return isSuperAdmin() || isBinaYoneticisi(binaId);
    }

    // Abonelik aktif mi?
    //   - 'omurboyu' planı → her zaman aktif
    //   - bitis alanı yoksa → aktif kabul et
    //   - durum 'aktif' veya 'grace' ise → aktif
    //   - Diğer durumlar → pasif (askida, iptal)
    function isAbonelikAktif(binaId) {
      let bina = get(/databases/$(database)/documents/binalar/$(binaId)).data;
      let plan  = bina.get('abonelik.plan', '');
      let durum = bina.get('abonelik.durum', 'aktif');
      return plan == 'omurboyu'
          || !('abonelik' in bina)
          || durum == 'aktif'
          || durum == 'grace';
    }

    // Abonelik kilitli değilse bile Süper Admin her zaman erişebilir
    function isYoneticiVeAktif(binaId) {
      return isSuperAdmin()
          || (isBinaYoneticisi(binaId) && isAbonelikAktif(binaId));
    }

    // Zorunlu alan kontrolü
    function hasRequired(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Güncellenen alanlar belirli set dışına çıkıyor mu?
    function onlyAllowed(allowed) {
      return request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(allowed);
    }

    // ─────────────────────────────────────────────────────────
    //  KURAL 0: Varsayılan — her şeyi reddet
    //  Aşağıdaki match blokları bunu seçici olarak açar.
    // ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────────────────
    //  SÜPER ADMİN CONFIG & LOGLAR
    // ─────────────────────────────────────────────────────────

    // admin/config — ilk kurulumda herkese açık okuma/yazma
    // Sonraki yazmalarda sadece kayıtlı admin yazabilir
    // NOT: masterHash olmadan zaten içeri girilemiyor — okuma güvenli
    match /anayonetici/config {
      // Okuma: herkese açık (masterHash doğrulaması client'ta yapılıyor)
      // Config yoksa ilk kurulum; varsa hash kontrolü admin.html'de
      allow read:   if true;
      // Oluşturma: config henüz yoksa herkese izin (ilk kurulum)
      allow create: if !exists(/databases/$(database)/documents/anayonetici/config);
      // Güncelleme: sadece içeriği bilen biri yapabilir
      // (masterHash doğrulaması client'ta yapıldıktan sonra çağrılır)
      allow update: if true;
      allow delete: if false;
    }

    // admin/logs — herkes yazar, okuma serbest
    match /anayonetici/logs/{logId} {
      allow read:   if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────
    //  BİNA META DÖKÜMAN  —  binalar/{binaId}
    // ─────────────────────────────────────────────────────────
    match /binalar/{binaId} {

      // Okuma:
      //   Süper Admin → her zaman
      //   Yönetici    → kendi binası, abonelik aktifse
      allow read: if isSuperAdmin()
               || (isBinaYoneticisi(binaId) && isAbonelikAktif(binaId));

      // Oluşturma: SADECE süper admin
      allow create: if isSuperAdmin()
                    && hasRequired(['binaAdi', 'yoneticiUid', 'abonelik']);

      // Güncelleme:
      //   Süper Admin → her alanı güncelleyebilir
      //   Yönetici    → abonelik ve yoneticiUid alanlarına DOKUNAMAZ
      allow update: if isSuperAdmin()
                 || (isBinaYoneticisi(binaId)
                     && isAbonelikAktif(binaId)
                     && !request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasAny(['abonelik', 'yoneticiUid', 'yoneticiEmail']));

      // Silme: SADECE süper admin
      allow delete: if isSuperAdmin();

      // ───────────────────────────────────────────────────────
      //  DAİRELER  —  binalar/{binaId}/daireler/{daireId}
      //
      //  Hiyerarşi:
      //    Süper Admin  → tam erişim (abonelik kontrolü yok)
      //    Yönetici     → tam erişim (abonelik aktifse)
      //    Sakin        → Firestore'a doğrudan erişimi yok
      // ───────────────────────────────────────────────────────
      match /daireler/{daireId} {
        allow read:   if isYoneticiVeAktif(binaId);
        allow create: if isYoneticiVeAktif(binaId)
                      && hasRequired(['daireNo', 'sifreHash']);
        allow update: if isYoneticiVeAktif(binaId);
        allow delete: if isYonetici(binaId); // Silme için abonelik kontrolü yok
      }

      // ───────────────────────────────────────────────────────
      //  KASA  —  binalar/{binaId}/kasa/{kasaId}
      //
      //  Hiyerarşi:
      //    Süper Admin → tam erişim
      //    Yönetici    → tam erişim (abonelik aktifse)
      //    Sakin       → erişim yok
      // ───────────────────────────────────────────────────────
      match /kasa/{kasaId} {
        allow read:   if isYoneticiVeAktif(binaId);
        allow create: if isYoneticiVeAktif(binaId)
                      && hasRequired(['tur', 'tutar', 'tarih']);
        allow update: if isYoneticiVeAktif(binaId);
        allow delete: if isYonetici(binaId);
      }

      // ───────────────────────────────────────────────────────
      //  KAMPANYALAR  —  binalar/{binaId}/kampanyalar/{kampId}
      //
      //  Hiyerarşi:
      //    Süper Admin → tam erişim
      //    Yönetici    → tam erişim (abonelik aktifse)
      //    Sakin       → sadece okuma (aktif kampanyalar)
      //                  NOT: Sakin Firebase Auth ile giriş
      //                  yapmadığı için bu kural tetiklenmez.
      //                  Gelecekte sakin token eklendiyse açılır.
      // ───────────────────────────────────────────────────────
      match /kampanyalar/{kampId} {
        allow read:   if isYoneticiVeAktif(binaId);
        allow create: if isYoneticiVeAktif(binaId)
                      && hasRequired(['baslik', 'durum']);
        allow update: if isYoneticiVeAktif(binaId);
        allow delete: if isYonetici(binaId);
      }

      // ───────────────────────────────────────────────────────
      //  ARIZALAR  —  binalar/{binaId}/arizalar/{arizaId}
      //
      //  Hiyerarşi:
      //    Süper Admin → tam erişim
      //    Yönetici    → tam erişim (abonelik aktifse)
      //    Sakin       → sadece create (kendi bildirimi)
      //                  [Sakin Firebase token alırsa açılır]
      // ───────────────────────────────────────────────────────
      match /arizalar/{arizaId} {
        allow read:   if isYoneticiVeAktif(binaId);
        allow create: if isYoneticiVeAktif(binaId)
                      && hasRequired(['baslik', 'daireNo', 'durum']);
        allow update: if isYoneticiVeAktif(binaId);
        allow delete: if isYonetici(binaId);
      }

      // ───────────────────────────────────────────────────────
      //  DUYURULAR  —  binalar/{binaId}/duyurular/{duyuruId}
      //
      //  Hiyerarşi:
      //    Süper Admin → tam erişim
      //    Yönetici    → tam erişim (abonelik aktifse)
      //    Sakin       → sadece okuma [token varsa]
      // ───────────────────────────────────────────────────────
      match /duyurular/{duyuruId} {
        allow read:   if isYoneticiVeAktif(binaId);
        allow create: if isYoneticiVeAktif(binaId)
                      && hasRequired(['baslik', 'icerik', 'tarih']);
        allow update: if isYoneticiVeAktif(binaId);
        allow delete: if isYonetici(binaId);
      }

      // ───────────────────────────────────────────────────────
      //  FATURALAR  —  binalar/{binaId}/faturalar/{faturaId}
      //
      //  Hiyerarşi:
      //    Süper Admin → tam erişim
      //    Yönetici    → tam erişim (abonelik aktifse)
      //    Sakin       → sadece okuma [token varsa]
      // ───────────────────────────────────────────────────────
      match /faturalar/{faturaId} {
        allow read:   if isYoneticiVeAktif(binaId);
        allow create: if isYoneticiVeAktif(binaId)
                      && hasRequired(['tur', 'tutar', 'donem']);
        allow update: if isYoneticiVeAktif(binaId);
        allow delete: if isYonetici(binaId);
      }

      // ───────────────────────────────────────────────────────
      //  BAKIM TAKVİMİ  —  binalar/{binaId}/bakim/{bakimId}
      //
      //  Hiyerarşi:
      //    Süper Admin → tam erişim
      //    Yönetici    → tam erişim (abonelik aktifse)
      //    Sakin       → erişim yok
      // ───────────────────────────────────────────────────────
      match /bakim/{bakimId} {
        allow read:   if isYoneticiVeAktif(binaId);
        allow create: if isYoneticiVeAktif(binaId)
                      && hasRequired(['ad', 'periodAy']);
        allow update: if isYoneticiVeAktif(binaId);
        allow delete: if isYonetici(binaId);
      }

      // ───────────────────────────────────────────────────────
      //  FİRMA REHBERİ  —  binalar/{binaId}/firmalar/{firmaId}
      //
      //  Hiyerarşi:
      //    Süper Admin → tam erişim
      //    Yönetici    → tam erişim (abonelik aktifse)
      //    Sakin       → erişim yok
      // ───────────────────────────────────────────────────────
      match /firmalar/{firmaId} {
        allow read:   if isYoneticiVeAktif(binaId);
        allow create: if isYoneticiVeAktif(binaId)
                      && hasRequired(['ad', 'kategori']);
        allow update: if isYoneticiVeAktif(binaId);
        allow delete: if isYonetici(binaId);
      }

      // ───────────────────────────────────────────────────────
      //  AYARLAR  —  binalar/{binaId}/settings/config
      //
      //  Hiyerarşi:
      //    Süper Admin → tam erişim
      //    Yönetici    → tam erişim (abonelik aktifse)
      //    Sakin       → sadece okuma [token varsa — aidat tutarı vb.]
      // ───────────────────────────────────────────────────────
      match /settings/config {
        allow read:   if isYoneticiVeAktif(binaId);
        allow write:  if isYoneticiVeAktif(binaId);
      }

      // ───────────────────────────────────────────────────────
      //  GENİŞLETİLEBİLİRLİK KURALI
      //
      //  Buraya tanımlanmamış yeni bir sub-collection eklenirse
      //  bu kural devreye girer. Yeni modül eklenince BURAYA
      //  ÖZEL KURAL YAZ ve bu catchall'u geçici tut.
      //
      //  PRODUCTION'da bu bloğu kaldır!
      // ───────────────────────────────────────────────────────
      match /{yeniKoleksiyon}/{docId} {
        allow read:  if isYoneticiVeAktif(binaId);
        allow write: if isYoneticiVeAktif(binaId);
      }

    } // /binalar/{binaId}

  } // /databases/{database}/documents
}
